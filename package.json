{
  "name": "tech-interview-prep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-content.mjs && node scripts/build-index.mjs && node scripts/dev.mjs",
    "dev:web": "vite",
    "rag": "node server/index.mjs",
    "api": "node server/api.mjs",
    "db:migrate": "node server/db/migrate.mjs",
    "db:seed": "node server/db/seed.mjs",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "content": "node scripts/build-content.mjs",
    "index": "node scripts/build-content.mjs && node scripts/build-index.mjs",
    "s3:upload": "npm run index && sh scripts/upload-s3.sh",
    "test": "node --test server/rag-core.test.mjs",
    "build": "node scripts/build-content.mjs && node scripts/build-index.mjs && tsc -b && vite build",
    "build:ci": "tsc -b && vite build",
    "build:blog": "node scripts/gen-blog-json.mjs && node scripts/build-blog.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "@types/prismjs": "^1.26.6",
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "latest",
    "pg": "^8.22.0",
    "prismjs": "^1.30.0",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "typescript": "latest",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
