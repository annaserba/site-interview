---
import Header from '../components/Header.astro'
import { ChatBot } from '../ChatBot'
import '../index.css'
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#161714" />
    <title>sobes-it | Вопросы с собеседований</title>
    <meta name="description" content="Знай, что тебя спросят. Вопросы компаний, короткие ответы и подробные разборы." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:opsz,wght@14..32,400..700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-intro">
        <div class="brand"><span class="brand-mark">s<span>/</span>i</span><span>sobes-it</span></div>
        <p>Сложные интервью становятся понятнее.</p>
      </div>
      <div class="footer-copy">
        <span>© 2026 sobes-it</span>
        <a href="/privacy">Политика конфиденциальности</a>
        <button class="theme-toggle" id="theme-toggle" title="Сменить тему" aria-label="Сменить тему">
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
    </footer>
    <ChatBot client:only="react" />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js')
      }

      // Theme toggle
      const html = document.documentElement
      const saved = localStorage.getItem('theme')
      if (saved) html.setAttribute('data-theme', saved)
      else if (window.matchMedia('(prefers-color-scheme: light)').matches) html.setAttribute('data-theme', 'light')

      document.getElementById('theme-toggle').addEventListener('click', () => {
        const current = html.getAttribute('data-theme')
        const next = current === 'light' ? 'dark' : 'light'
        html.setAttribute('data-theme', next)
        localStorage.setItem('theme', next)
      })
    </script>
  </body>
</html>

<style>
  main { min-height: 60vh; }
  .site-footer {
    min-height: 200px; padding: 40px 20px;
    background: var(--dark); color: white;
    display: flex; flex-direction: column; gap: 20px;
  }
  .site-footer p { color: #777970; font-size: 12px; line-height: 1.6; margin: 0; }
  .footer-intro { display: flex; flex-direction: column; gap: 8px; }
  .footer-copy {
    display: flex; gap: 16px; align-items: center;
    font-size: 12px; color: #777970;
  }
  .footer-copy a { color: var(--acid); font-size: 11px; }
  .theme-toggle {
    border: 1px solid var(--dark-line); border-radius: 8px;
    background: transparent; color: #c7c9c1;
    width: 34px; height: 34px; display: grid; place-items: center;
    cursor: pointer; transition: all .2s;
    margin-left: auto;
  }
  .theme-toggle:hover { border-color: var(--acid); color: var(--acid); }
  :root[data-theme='dark'] .icon-moon { display: none; }
  :root[data-theme='light'] .icon-sun { display: none; }
  @media (min-width: 761px) {
    .site-footer { flex-direction: row; gap: 55px; padding: 48px 5.5vw; }
    .footer-copy { margin-left: auto; }
  }
</style>
