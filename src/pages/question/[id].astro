---
import Base from '../../layouts/Base.astro'
import { mapQuestion } from '../../api'
import questionsData from '../../data/questions.json'

export function getStaticPaths() {
  return questionsData.map((q: any) => ({
    params: { id: q.id },
    props: { question: mapQuestion(q) },
  }))
}

const { question } = Astro.props
---

<Base>
  <div style="max-width: 800px; margin: 0 auto; padding: 32px 20px 80px;">
    <QuestionDetail question={question} client:only="react" />
  </div>
</Base>
