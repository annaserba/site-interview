---
import Base from '../../layouts/Base.astro'
import { blogArticles } from '../../blog-articles'
import { marked } from 'marked'

export function getStaticPaths() {
  return blogArticles.map(a => ({
    params: { id: a.id },
    props: { article: a },
  }))
}

const { article } = Astro.props
const htmlContent = marked.parse(article.content) as string
---

<Base>
  <article class="page">
    <a href="/blog" class="back">← Блог</a>
    <div class="tags">
      {article.tags.map((t: string) => <span class="tag">{t}</span>)}
    </div>
    <h1>{article.title}</h1>
    <p class="meta">{article.readTime} мин чтения</p>
    <div class="content" set:html={htmlContent} />
  </article>
</Base>

<style>
  .page { max-width: 720px; margin: 0 auto; padding: 40px 20px 80px; }
  .back { color: var(--muted); font-size: 13px; text-decoration: none; display: inline-block; margin-bottom: 20px; }
  .back:hover { color: var(--ink); }
  .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; }
  .tag { font-size: 10px; text-transform: uppercase; letter-spacing: .06em; color: var(--acid); background: var(--acid-glow); padding: 3px 8px; border-radius: 999px; font-weight: 600; }
  h1 { font-size: 28px; margin: 0 0 8px; line-height: 1.3; }
  .meta { color: var(--muted); font-size: 13px; margin: 0 0 32px; }
  .content { line-height: 1.7; font-size: 15px; }
  .content :global(h2) { font-size: 20px; margin: 32px 0 12px; }
  .content :global(h3) { font-size: 17px; margin: 24px 0 8px; }
  .content :global(p) { margin: 0 0 14px; }
  .content :global(ul), .content :global(ol) { margin: 8px 0 16px; padding-left: 20px; }
  .content :global(li) { margin-bottom: 4px; }
  .content :global(code) { font-family: 'JetBrains Mono', monospace; font-size: 13px; background: var(--surface); padding: 2px 6px; border-radius: 4px; }
  .content :global(pre) { background: var(--surface); padding: 16px; border-radius: 8px; overflow-x: auto; font-size: 13px; }
  .content :global(pre code) { background: none; padding: 0; }
  @media (min-width: 761px) { h1 { font-size: 36px; } .page { padding: 80px 5.5vw 100px; } }
</style>
