DB_PASSWORD=change_me

# Адрес сайта, который видит пользователь.
FRONTEND_URL=http://sobes-it.ru/

# Этот URL должен быть один-в-один добавлен в настройках OAuth-приложения Яндекса.
YANDEX_REDIRECT_URI=http://sobes-it.ru/api/auth/yandex/callback

# Значения из OAuth-приложения Яндекса.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Любая длинная случайная строка. Менять после запуска нельзя: изменятся хэши телефонов.
PHONE_SALT=change_me_to_long_random_string

# Для http/IP оставить false. Для https-домена поставить true.
SESSION_COOKIE_SECURE=false
