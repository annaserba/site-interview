FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install --omit=dev

COPY server/ ./server/
COPY src/data/questions.json ./src/data/questions.json
COPY public/data/ ./public/data/

EXPOSE 3001

CMD ["sh", "-c", "node server/db/migrate.mjs && node server/db/seed.mjs && node server/api.mjs"]
