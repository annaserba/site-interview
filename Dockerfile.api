FROM node:20-alpine

WORKDIR /app

# Only install production dependency
RUN echo '{"dependencies":{"pg":"^8.22.0"}}' > package.json && npm install --omit=dev

COPY server/ ./server/
COPY src/data/questions.json ./src/data/questions.json
COPY public/data/ ./public/data/

EXPOSE 3001

CMD ["server/entrypoint.sh"]
